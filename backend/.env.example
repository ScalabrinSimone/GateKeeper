# ============================================================
# GateKeeper — variabili d'ambiente
# ============================================================
# Copia questo file in ".env" e compila i valori reali.
# Il file .env NON va mai committato su Git (vedi .gitignore).

# --- Database ---
# Stringa di connessione SQLAlchemy.
# Formato SQLite (sviluppo locale):  sqlite+aiosqlite:///./gatekeeper.db
# Formato PostgreSQL (produzione):   postgresql+asyncpg://user:pass@localhost/gatekeeper
DATABASE_URL=sqlite+aiosqlite:///./gatekeeper.db

# --- JWT ---
# Chiave segreta usata per firmare i token JWT.
# Genera un valore sicuro con:  openssl rand -hex 32
SECRET_KEY=cambia_questa_chiave_con_openssl_rand_hex_32

# Algoritmo di firma (HS256 = HMAC-SHA256, va bene per uso interno)
ALGORITHM=HS256

# Durata del token di accesso in minuti (default 60 = 1 ora)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Origini permesse separate da virgola.
# In sviluppo puoi mettere * (qualsiasi origine).
# In produzione metti l'URL del tunnel Cloudflare o del tuo dominio.
ALLOWED_ORIGINS=http://localhost,http://localhost:8080

# --- App ---
APP_NAME=GateKeeper
APP_VERSION=0.1.0
DEBUG=true
