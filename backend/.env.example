# ── GateKeeper – variabili d'ambiente (copia in .env e compila) ───────────────
# ATTENZIONE: .env NON deve essere committato su GitHub (è in .gitignore)

# Chiave segreta JWT – genera con: openssl rand -hex 32
SECRET_KEY=sostituisci_con_una_stringa_random_lunga

# Durata token in minuti
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (lascia SQLite in sviluppo)
DATABASE_URL=sqlite:///./gatekeeper.db
# Per PostgreSQL:
# DATABASE_URL=postgresql://gatekeeper:password@localhost/gatekeeper_db

# Origini CORS permesse (in produzione metti il dominio Cloudflare)
ALLOWED_ORIGINS=["*"]
# In produzione:
# ALLOWED_ORIGINS=["https://gatekeeper.tuodominio.com"]
